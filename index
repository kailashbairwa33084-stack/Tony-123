<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Tony Security</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/emailjs-com@3/dist/email.min.js"></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Poppins', sans-serif; background: #f5f7fa; color: #222; }
    header { position: fixed; top: 0; width: 100%; background: rgba(0,0,0,0.7); color: #fff; padding: 15px 20px; display: flex; justify-content: space-between; align-items: center; z-index: 1000; }
    header h1 { font-size: 18px; }
    header span { font-size: 12px; color: #ccc; }

    .hero { height: 100vh; background: url('https://i.ibb.co/bR8R0BvV/IMG-0895.jpg') center/cover no-repeat; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; color: #fff; padding: 20px; }
    .hero h2 { font-size: 36px; margin-bottom: 15px; text-shadow: 2px 2px 10px rgba(0,0,0,0.7); }
    .hero button { padding: 12px 25px; border: none; background: #ff6600; color: #fff; font-size: 16px; border-radius: 30px; cursor: pointer; }

    .products { padding: 80px 20px; }
    .products h3 { text-align: center; margin-bottom: 20px; }

    .carousel { display: flex; overflow-x: auto; gap: 15px; scroll-behavior: smooth; }
    .card { min-width: 250px; background: #fff; border-radius: 15px; padding: 15px; box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
    .card img { width: 100%; border-radius: 10px; }
    .card h4 { margin: 10px 0; }
    .card p { font-weight: bold; margin-bottom: 10px; }
    .card button { width: 100%; padding: 8px; border: none; background: #111; color: #fff; border-radius: 20px; cursor: pointer; }

    .cart-icon { position: fixed; bottom: 80px; right: 20px; background: #111; color: #fff; width: 50px; height: 50px; border-radius: 50%; display: flex; justify-content: center; align-items: center; cursor: pointer; }
    .cart-count { position: absolute; top: -5px; right: -5px; background: red; color: #fff; width: 20px; height: 20px; font-size: 12px; border-radius: 50%; display: flex; justify-content: center; align-items: center; }

    .cart-drawer { position: fixed; right: -100%; top: 0; width: 300px; height: 100%; background: #fff; box-shadow: -5px 0 15px rgba(0,0,0,0.2); padding: 20px; transition: 0.4s; overflow-y: auto; }
    .cart-drawer.active { right: 0; }
    .cart-drawer h3 { margin-bottom: 10px; }
    .cart-item { margin-bottom: 10px; border-bottom: 1px solid #ddd; padding-bottom: 5px; }

    .form-group { margin-bottom: 10px; }
    input { width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 5px; }
    .send-btn { width: 100%; padding: 10px; border: none; background: #ff6600; color: #fff; border-radius: 20px; cursor: pointer; margin-top: 10px; }

    .whatsapp { position: fixed; bottom: 20px; right: 20px; background: #25D366; width: 55px; height: 55px; border-radius: 50%; display: flex; justify-content: center; align-items: center; color: #fff; font-size: 28px; text-decoration: none; }
  </style>
</head>
<body>

<header>
  <div>
    <h1>The Tony Security</h1>
    <span>Feel Secure With Us</span>
  </div>
</header>

<section class="hero">
  <h2>Advanced CCTV Security Solutions</h2>
  <button onclick="document.getElementById('products').scrollIntoView({behavior:'smooth'})">Shop Now</button>
</section>

<section class="products" id="products">
  <h3>Our Products</h3>
  <div class="carousel">
    <div class="card">
      <img src="https://i.ibb.co/6094SxcF/17722861415271995129841292426942.jpg" alt="Camera">
      <h4>HD Security Camera</h4>
      <p>₹2000</p>
      <button onclick="addToCart('HD Security Camera',2000)">Add to Cart</button>
    </div>
  </div>
</section>

<div class="cart-icon" onclick="toggleCart()">
  🛒
  <div class="cart-count" id="cartCount">0</div>
</div>

<div class="cart-drawer" id="cartDrawer">
  <h3>Your Cart</h3>
  <div id="cartItems"></div>
  <div class="form-group">
    <input type="text" id="customerName" placeholder="Your Name" required>
  </div>
  <div class="form-group">
    <input type="text" id="customerPhone" placeholder="Phone Number" required>
  </div>
  <button class="send-btn" onclick="sendOrder()">Send Order</button>
</div>

<a href="https://wa.me/917357517683" class="whatsapp" target="_blank">💬</a>

<script>
  emailjs.init("YOUR_PUBLIC_KEY");

  let cart = [];

  function addToCart(name, price) {
    cart.push({name, price});
    updateCart();
  }

  function updateCart() {
    document.getElementById('cartCount').innerText = cart.length;
    const cartItems = document.getElementById('cartItems');
    cartItems.innerHTML = '';
    cart.forEach(item => {
      cartItems.innerHTML += `<div class='cart-item'>${item.name} - ₹${item.price}</div>`;
    });
  }

  function toggleCart() {
    document.getElementById('cartDrawer').classList.toggle('active');
  }

  function sendOrder() {
    const name = document.getElementById('customerName').value;
    const phone = document.getElementById('customerPhone').value;
    if(!name || !phone || cart.length === 0) {
      alert('Please fill all details and add product.');
      return;
    }
    let items = cart.map(item => `${item.name} - ₹${item.price}`).join('\n');

    emailjs.send("YOUR_SERVICE_ID","YOUR_TEMPLATE_ID",{
      customer_name: name,
      customer_phone: phone,
      order_details: items,
      to_email: "asindtony@gmail.com"
    }).then(()=>{
      alert('Order Sent Successfully!');
      cart = [];
      updateCart();
      toggleCart();
    },(error)=>{
      alert('Failed to send order.');
    });
  }
</script>

</body>
</html>
